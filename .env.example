# Alpha Vantage API key (free: https://www.alphavantage.co/support/#api-key)
# Use "demo" for limited mock data
ALPHA_VANTAGE_API_KEY=demo

# Twitter/X target account(s) to monitor (comma-separated)
SCRAPE_TARGET=@realDonaldTrump

# Platform to scrape (twitter or truthsocial)
SCRAPE_PLATFORM=truthsocial

# Polling interval in minutes for monitor mode
POLL_INTERVAL_MINUTES=5

# Output directory for JSON reports
OUTPUT_DIR=./output

# Log level: debug | info | warn | error
LOG_LEVEL=info
